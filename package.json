{
  "name": "movie-search-engine",
  "version": "1.0.0",
  "description": "Movie Search Engine - Full Stack",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:separate": "start-separate.bat",
    "dev:windows:separate": "start-separate.bat",
    "start": "concurrently \"npm start --prefix backend\" \"npm start --prefix frontend\"",
    "backend": "npm run dev --prefix backend",
    "frontend": "npm run dev --prefix frontend",
    "install-all": "npm install && npm install --prefix backend && npm install --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}